<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:vm="using:BirthdayReminder.ViewModels"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="150"
		x:Class="BirthdayReminder.EditRecordWindow"
		x:DataType="vm:EditorWindowViewModel"
		Title="EditRecordWindow" Padding="10" Width="400" Height="150">
	<DockPanel>
		<Grid DockPanel.Dock="Top" RowSpacing="10" ColumnSpacing="10" ColumnDefinitions="auto, *" RowDefinitions="auto, auto" >
			<TextBlock Grid.Column="0" Grid.Row="0" Text="Name" VerticalAlignment="Center"/>
			<TextBox Grid.Column="1" Grid.Row="0" Text="{Binding Record.Name}"/>

			<TextBlock Grid.Column="0" Grid.Row="1" Text="Date of birth" VerticalAlignment="Center"/>
			<CalendarDatePicker Grid.Row="1" Grid.Column="1"/>
		</Grid>
		<StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right" VerticalAlignment="Bottom" DockPanel.Dock="Bottom" >
			<Button Content="Save" Command="{Binding SaveCommand}"/>
			<Button Content="Cancel" Command="{Binding CancelCommand}"/>
		</StackPanel>
	</DockPanel>
</Window>
